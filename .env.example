# Copia este archivo a .env.local para desarrollo local (no se sube a git)
# En producción, configura estos valores en Vercel → Project Settings → Environment Variables

# === MongoDB Atlas ===
MONGODB_URI="mongodb+srv://USUARIO:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB="tao_ahorro"

# === Autenticación ===
# Generar con: node scripts/hash-pin.js TU_PIN
PIN_HASH="$2a$10$..."
# Secreto para firmar tokens JWT (cualquier string aleatorio largo)
JWT_SECRET="cambia-esto-por-un-string-aleatorio-largo-de-al-menos-32-caracteres"

# === Correo Gmail ===
# Crea un "App Password" en https://myaccount.google.com/apppasswords
GMAIL_USER="tu-correo@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
EMAIL_DESTINO="tu-correo@gmail.com"

# === Cron / GitHub Actions ===
CRON_SECRET="otro-string-aleatorio-largo-para-proteger-el-cron"

# === CORS ===
# URL de tu GitHub Pages (sin slash al final)
ALLOWED_ORIGIN="https://TU-USUARIO.github.io"

# === Recordatorios ===
DIAS_ALERTA_INACTIVIDAD="7"
